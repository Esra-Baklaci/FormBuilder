@model IEnumerable<DynamicFormBuilder.Business.Models.FormListItemDto>
@{
    ViewData["Title"] = "Formlar";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="app-page-title">Form Yönetimi</h1>
        <p class="app-page-subtitle">Tüm formlarınızı buradan yönetin</p>
    </div>
    <a asp-action="Create" class="btn btn-fb btn-fb-primary"><i class="bi bi-plus-lg me-1"></i>Yeni Form</a>
</div>

<div class="card app-card">
    <div class="table-responsive">
        <table class="table app-table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th>Başlık</th>
                    <th>Slug</th>
                    <th>Alan</th>
                    <th>Yanıt</th>
                    <th>Durum</th>
                    <th>Oluşturma</th>
                    <th class="text-end">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="7" class="text-center text-muted py-5">Henüz form oluşturulmadı.</td></tr>
                }
                @foreach (var form in Model)
                {
                    <tr>
                        <td class="fw-semibold">@form.Title</td>
                        <td><code>@form.Slug</code></td>
                        <td>@form.FieldCount</td>
                        <td>@form.ResponseCount</td>
                        <td>
                            @if (form.IsPublished)
                            {
                                <span class="badge badge-soft-success rounded-pill">Yayında</span>
                            }
                            else
                            {
                                <span class="badge badge-soft-secondary rounded-pill">Taslak</span>
                            }
                            @if (!form.IsActive)
                            {
                                <span class="badge badge-soft-warning rounded-pill">Pasif</span>
                            }
                        </td>
                        <td>@form.CreatedAt.ToLocalTime().ToString("g")</td>
                        <td class="text-end">
                            <div class="app-table-actions">
                                <a asp-controller="FormBuilder" asp-action="Index" asp-route-id="@form.Id" class="btn btn-fb btn-fb-soft" title="Builder"><i class="bi bi-bricks"></i></a>
                                <a asp-action="Preview" asp-route-id="@form.Id" class="btn btn-fb btn-fb-outline" title="Önizleme"><i class="bi bi-eye"></i></a>
                                <a asp-action="Edit" asp-route-id="@form.Id" class="btn btn-fb btn-fb-outline" title="Düzenle"><i class="bi bi-pencil"></i></a>
                                <a asp-controller="Response" asp-action="Index" asp-route-formId="@form.Id" class="btn btn-fb btn-fb-outline" title="Yanıtlar"><i class="bi bi-inbox"></i></a>
                                <form asp-action="Copy" asp-route-id="@form.Id" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-fb btn-fb-outline" title="Kopyala"><i class="bi bi-copy"></i></button>
                                </form>
                                <form asp-action="ToggleActive" asp-route-id="@form.Id" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-fb btn-fb-outline" title="Aktif/Pasif"><i class="bi bi-toggle-on"></i></button>
                                </form>
                                <form asp-action="Delete" asp-route-id="@form.Id" method="post" class="d-inline" onsubmit="return confirm('Form silinsin mi?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-fb btn-fb-danger-outline" title="Sil"><i class="bi bi-trash"></i></button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
