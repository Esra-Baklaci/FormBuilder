@model IEnumerable<DynamicFormBuilder.Business.Models.ResponseListItemDto>
@{
    var form = ViewBag.Form as DynamicFormBuilder.Business.Models.FormDetailDto;
    ViewData["Title"] = "Yanıtlar - " + form?.Title;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h4 mb-1">Form Yanıtları</h1>
        <p class="text-muted mb-0">@form?.Title</p>
    </div>
    <div class="btn-group">
        <a asp-action="ExportExcel" asp-route-formId="@form?.Id" class="btn btn-success btn-sm">
            <i class="bi bi-file-earmark-excel me-1"></i>Excel Export
        </a>
        <a asp-controller="Form" asp-action="Index" class="btn btn-outline-secondary btn-sm">Formlara Dön</a>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>ID</th>
                    <th>Gönderim Tarihi</th>
                    <th>IP</th>
                    <th>Alan Sayısı</th>
                    <th class="text-end">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="5" class="text-center text-muted py-4">Henüz yanıt yok.</td></tr>
                }
                @foreach (var item in Model)
                {
                    <tr>
                        <td>#@item.Id</td>
                        <td>@item.SubmittedAt.ToLocalTime().ToString("g")</td>
                        <td>@(item.IpAddress ?? "-")</td>
                        <td>@item.ValueCount</td>
                        <td class="text-end">
                            <div class="btn-group btn-group-sm">
                                <a asp-action="Detail" asp-route-id="@item.Id" class="btn btn-outline-primary">Detay</a>
                                <a asp-action="ExportPdf" asp-route-id="@item.Id" class="btn btn-outline-secondary">PDF</a>
                                <form asp-action="Delete" asp-route-id="@item.Id" asp-route-formId="@form?.Id" method="post" class="d-inline" onsubmit="return confirm('Yanıt silinsin mi?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-outline-danger">Sil</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
